# Enforce LF on scripts + shebang/text formats the build and runtime execute (gap M13):
# a CRLF shebang makes dash/sh look for "/bin/sh" and silently fail install steps,
# which the manager Dockerfile currently strips at build time. Committing LF here makes
# the image build a plain compile.
*.sh    text eol=lf
*.bash  text eol=lf
install.sh text eol=lf
*.py    text eol=lf
*.pl    text eol=lf
Makefile text eol=lf
*.mk    text eol=lf

# Package-generation manifests + templates the agent postinst reads at install time.
# A CRLF here gets baked into the built .deb/.rpm and corrupts SCA policy filenames
# (mv "cis_*.yml"$'\r' fails) and generated config — a ship-blocker found in E2E testing.
sca.files    text eol=lf
*.template   text eol=lf
*.files      text eol=lf
etc/templates/** text eol=lf
src/init/**  text eol=lf
