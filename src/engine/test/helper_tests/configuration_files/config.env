# Used only for testing purposes
GUARDSARM_REVERSE_ORDER_DECODERS=false

# Used for engine standalone
GUARDSARM_ENGINE_STANDALONE=true

# Sets the logging level.
GUARDSARM_STANDALONE_LOG_LEVEL=debug

# Sets the path to the folder where the assets are located (store).
GUARDSARM_STORE_PATH=ENV_PATH_PLACEHOLDER/store

# Sets the path to the outputs base folder. The engine resolves outputs from
# <base>/default/ or <base>/<space>/.
GUARDSARM_OUTPUTS_PATH=ENV_PATH_PLACEHOLDER/outputs

# Sets the path to the default kvdb folder.
GUARDSARM_KVDB_IOC_PATH=ENV_PATH_PLACEHOLDER/kvdb-ioc

# Sets the path to the Ruleset Store folder.
GUARDSARM_CM_RULESET_PATH=ENV_PATH_PLACEHOLDER/content

# Sets the number of threads to be used by the router.
GUARDSARM_ORCHESTRATOR_THREADS=2

# Set the server configuration
GUARDSARM_SERVER_THREAD_POOL_SIZE=2
GUARDSARM_SERVER_EVENT_QUEUE_SIZE=0
GUARDSARM_SERVER_API_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/engine-api.socket
GUARDSARM_SERVER_API_QUEUE_SIZE=300
GUARDSARM_SERVER_API_TIMEOUT=10000
GUARDSARM_SERVER_EVENT_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/engine.socket
GUARDSARM_SERVER_ENRICHED_EVENTS_SOCKET=ENV_PATH_PLACEHOLDER/queue/sockets/queue-http.sock

# Sets the install path to the time zone database.
GUARDSARM_TZDB_PATH=ENV_PATH_PLACEHOLDER/tzdb
GUARDSARM_TZDB_AUTO_UPDATE=true

# Configure dumper
GUARDSARM_DUMPER_ENABLED=false

# Streamlog
GUARDSARM_STREAMLOG_BASE_PATH=ENV_PATH_PLACEHOLDER/logs

# Configure geolocation manager
GUARDSARM_GEO_DB_PATH=ENV_PATH_PLACEHOLDER/geo
GUARDSARM_GEO_MANIFEST_URL=http://127.0.0.1:8000/manifest.json
GUARDSARM_GEO_SYNC_INTERVAL=0

# Configure IOC sync
GUARDSARM_IOC_SYNC_INTERVAL=0

GUARDSARM_STANDALONE_LOG_FILE_PATH=ENV_PATH_PLACEHOLDER/logs/guardsarm-engine.log
GUARDSARM_STANDALONE_LOG_ROTATION_ENABLED=false
