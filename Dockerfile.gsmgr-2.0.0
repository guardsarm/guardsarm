# GuardSarm manager 2.0.0 — re-applies runtime config onto the flattened 2.0.0
# rootfs (exported from the running gsmgr container; a corrupted content-store layer
# blocked a plain `docker commit`). Filesystem carries the 2.0.0 version data.
FROM guardsarm-manager:2.0.0-rootfs

ENV PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    LD_LIBRARY_PATH=/var/gsmsec/lib:/var/gsmsec/framework/python/lib

WORKDIR /build/guardsarm
EXPOSE 1514/tcp 1515/tcp 1516/tcp 55000/tcp

CMD ["/bin/sh","-c","bash -c '  ( /var/gsmsec/bin/guardsarm-manager-control start || /var/gsmsec/bin/guardsarm-control start || true );   sleep 8;   echo \"=== GuardSarm daemons ===\"; /var/gsmsec/bin/guardsarm-manager-control status 2>/dev/null || /var/gsmsec/bin/guardsarm-control status 2>/dev/null || ps -e;   touch /var/gsmsec/logs/ossec.log; tail -f /var/gsmsec/logs/ossec.log'"]
